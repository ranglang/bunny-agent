# syntax=docker/dockerfile:1
# Bunny Agent Image (vikadata/bunny-agent)
# Pre-installs runner-cli, @bunny-agent/daemon (HTTP API), and @anthropic-ai/claude-agent-sdk
# Compatible with both Daytona Snapshots and E2B custom templates
#
# E2B: Use Template.fromDockerfile() to parse this Dockerfile
# Daytona: Use daytona snapshot push or daytona snapshot create --dockerfile
#
# Build with BuildKit (default in Docker 23+): enables apt cache mounts for faster rebuilds.
# First build is still slow: `playwright install --with-deps chromium` pulls many .deb packages.

FROM node:20-slim

# Version of @bunny-agent/runner-cli to install.
# Override at build time: docker build --build-arg RUNNER_CLI_VERSION=1.2.3 ...
ARG RUNNER_CLI_VERSION=0.9.29-beta.0

LABEL org.opencontainers.image.title="bunny-agent"
LABEL org.opencontainers.image.description="Bunny Agent with Claude Agent SDK pre-installed"
LABEL org.opencontainers.image.version="$RUNNER_CLI_VERSION"

# Install common tools + nginx (CDP proxy). Apt cache mounts speed up repeated local builds.
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt/lists,sharing=locked \
    for i in 1 2 3; do \
    apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    sudo \
    tmux \
    python3 \
    python3-pip \
    nginx \
    && rm -rf /var/lib/apt/lists/* \
    && break || sleep 5; \
    done

# Create agent user with home directory
RUN useradd -m -d /agent -s /bin/bash agent && \
    echo "agent ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Create directories with proper permissions
RUN mkdir -p /workspace && chown agent:agent /workspace
WORKDIR /workspace

# Pre-install dependencies to /opt/bunny-agent (won't be overwritten by volume mount)
RUN mkdir -p /opt/bunny-agent && \
    cd /opt/bunny-agent && \
    npm init -y && \
    npm install --no-audit --no-fund \
    @anthropic-ai/claude-agent-sdk \
    @bunny-agent/runner-cli@${RUNNER_CLI_VERSION} \
    @bunny-agent/daemon@${RUNNER_CLI_VERSION} \
    playwright && \
    rm package.json package-lock.json && \
    npm cache clean --force && \
    chown -R agent:agent /opt/bunny-agent

# Install Playwright Chromium browser and system dependencies.
# Refresh apt signing keys before Playwright runs apt-get again: under buildx+QEMU
# (linux/amd64 on Apple Silicon), apt can fail with "invalid signature" without this.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/bunny-agent/pw-browsers
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      debian-archive-keyring \
      gnupg \
    && cd /opt/bunny-agent \
    && DEBIAN_FRONTEND=noninteractive npx playwright install --with-deps chromium \
    && rm -rf /var/lib/apt/lists/*

RUN npm install simple-git brave-search-cli -g

# Create init script to copy deps to workspace on startup
RUN echo '#!/bin/bash\n\
if [ ! -d "/workspace/node_modules/@bunny-agent" ]; then\n\
  echo "Copying bunny-agent dependencies to workspace..."\n\
  mkdir -p /workspace/node_modules\n\
  cp -r /opt/bunny-agent/node_modules/* /workspace/node_modules/\n\
fi\n\
exec "$@"' > /usr/local/bin/bunny-agent-init && \
    chmod +x /usr/local/bin/bunny-agent-init

# Create runner CLI command in /usr/local/bin
RUN echo '#!/usr/bin/env node' > /usr/local/bin/bunny-agent && \
    echo 'import("/opt/bunny-agent/node_modules/@bunny-agent/runner-cli/dist/bundle.mjs")' >> /usr/local/bin/bunny-agent && \
    chmod +x /usr/local/bin/bunny-agent

# bunny-agent-daemon: HTTP gateway (fs, git, volumes, /api/coding/run)
RUN echo '#!/usr/bin/env node' > /usr/local/bin/bunny-agent-daemon && \
    echo 'import("/opt/bunny-agent/node_modules/@bunny-agent/daemon/dist/bundle.mjs")' >> /usr/local/bin/bunny-agent-daemon && \
    chmod +x /usr/local/bin/bunny-agent-daemon

# Entrypoint: run init hooks, copy /skills, start daemon + optional CDP, then exec CMD
RUN printf '%s\n' \
    '#!/bin/bash' \
    '# Run all init hooks (drop scripts into /etc/bunny-agent-init.d/)' \
    'if [ -d /etc/bunny-agent-init.d ]; then' \
    '  for f in /etc/bunny-agent-init.d/*.sh; do' \
    '    [ -x "$f" ] && "$f"' \
    '  done' \
    'fi' \
    'mkdir -p "$HOME/.claude/skills"' \
    'if [ -d /skills ] && [ -n "$(ls -A /skills 2>/dev/null)" ]; then' \
    '  cp -r /skills/. "$HOME/.claude/skills/"' \
    '  echo "Copied /skills to $HOME/.claude/skills"' \
    'fi' \
    'bunny-agent-daemon &' \
    'case "${START_CDP_ON_INIT:-1}" in' \
    '  0) echo "CDP startup disabled by START_CDP_ON_INIT=0" ;;' \
    '  *) start-cdp ;;' \
    'esac' \
    'exec "$@"' > /usr/local/bin/bunny-agent-entrypoint && \
    chmod +x /usr/local/bin/bunny-agent-entrypoint && \
    mkdir -p /etc/bunny-agent-init.d

# Set environment variables
ENV NODE_PATH=/opt/bunny-agent/node_modules
ENV PATH=/usr/local/bin:$PATH
ENV SANDAGENT_ROOT=/agent
ENV SANDAGENT_DAEMON_HOST=0.0.0.0
ENV SANDAGENT_DAEMON_PORT=3080
ENV START_CDP_ON_INIT=1

# Suppress D-Bus errors in headless Chromium (no bus in containers)
ENV DBUS_SESSION_BUS_ADDRESS=/dev/null

# Create CDP (Chrome DevTools Protocol) startup script
# Use nginx to proxy and rewrite Host header to localhost,
# bypassing Chromium's Host header security check
RUN echo 'server {\n\
    listen 9222;\n\
    location / {\n\
        proxy_pass http://127.0.0.1:9223;\n\
        proxy_set_header Host localhost;\n\
        proxy_http_version 1.1;\n\
        proxy_set_header Upgrade $http_upgrade;\n\
        proxy_set_header Connection "upgrade";\n\
    }\n\
}' > /etc/nginx/conf.d/cdp-proxy.conf && \
    rm -f /etc/nginx/sites-enabled/default

RUN echo '#!/bin/bash\n\
set -e\n\
CHROME_BIN=$(node -e "console.log(require('"'"'playwright'"'"').chromium.executablePath())")\n\
"$CHROME_BIN" --headless --no-sandbox --disable-gpu --disable-dev-shm-usage --disable-software-rasterizer \\\n\
  --window-size=1280,800 --force-device-scale-factor=1 \\\n\
  --remote-debugging-port=9223 --remote-allow-origins=* 2>/dev/null &\n\
for i in $(seq 1 30); do\n\
  if curl -s http://127.0.0.1:9223/json/version > /dev/null 2>&1; then break; fi\n\
  sleep 0.5\n\
done\n\
sudo nginx\n\
echo "CDP available on 0.0.0.0:9222 (nginx proxy rewriting Host to localhost)"' > /usr/local/bin/start-cdp && \
    chmod +x /usr/local/bin/start-cdp

# Switch to agent user
USER agent

# Template files (optional, added by build script)

# Copy /skills into ~/.claude/skills at startup, then keep container running (for Daytona)
ENTRYPOINT ["/usr/local/bin/bunny-agent-entrypoint"]

# Expose bunny-agent-daemon HTTP (healthz, fs, git, coding) and CDP (browser automation)
EXPOSE 3080
EXPOSE 9222

# Keep container alive (daemon + CDP started by entrypoint)
CMD ["sleep", "infinity"]
