# SandAgent Image - build from local monorepo (no npm publish)
# Copies and builds runner-cli + runner-claude from repo; only installs claude-agent-sdk from npm.
#
# Build from repo root (use .dockerignore at repo root to exclude node_modules, .git, etc.):
#   docker build -f docker/sandagent-claude/Dockerfile.local -t vikadata/sandagent:local .

# -----------------------------------------------------------------------------
# Stage 1: build runner-cli bundle from local source
# -----------------------------------------------------------------------------
FROM node:20-slim AS builder

WORKDIR /build

RUN corepack enable && corepack prepare pnpm@10.11.0 --activate && pnpm --version

# Copy full repo so pnpm workspace resolves (context = repo root)
COPY . .

# Install and build runner chain + daemon (daemon bundles runner-core)
RUN pnpm install --frozen-lockfile && \
    pnpm --filter @sandagent/manager build && \
    pnpm --filter @sandagent/runner-core build && \
    pnpm --filter @sandagent/runner-claude build && \
    pnpm --filter @sandagent/runner-cli build && \
    pnpm --filter @sandagent/daemon build

# -----------------------------------------------------------------------------
# Stage 2: runtime image with local bundle + claude-agent-sdk from npm
# -----------------------------------------------------------------------------
FROM node:20-slim

LABEL org.opencontainers.image.title="sandagent"
LABEL org.opencontainers.image.description="SandAgent with Claude Agent SDK (local runner build)"
LABEL org.opencontainers.image.version="0.1.0"

RUN for i in 1 2 3; do \
    apt-get update && apt-get install -y git curl python3 python3-pip && rm -rf /var/lib/apt/lists/* && break || sleep 5; \
    done

RUN mkdir -p /workspace && chmod 777 /workspace
WORKDIR /workspace

# Install only runtime dep (runner code is in bundle)
RUN mkdir -p /opt/sandagent/node_modules && \
    cd /opt/sandagent && npm init -y && \
    npm install --no-audit --no-fund @anthropic-ai/claude-agent-sdk playwright && \
    rm package.json package-lock.json && npm cache clean --force

# Install Playwright Chromium browser and system dependencies.
# Refresh apt keys before Playwright's apt-get (buildx+QEMU amd64 on arm64 hosts).
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/sandagent/pw-browsers
RUN apt-get update && \
    apt-get install -y --no-install-recommends --reinstall \
      ca-certificates \
      debian-archive-keyring \
      gnupg \
    && rm -rf /var/lib/apt/lists/* \
    && cd /opt/sandagent \
    && DEBIAN_FRONTEND=noninteractive npx playwright install --with-deps chromium

# Copy local-built runner and daemon bundles into place
RUN mkdir -p /opt/sandagent/node_modules/@sandagent/runner-cli/dist \
    /opt/sandagent/node_modules/@sandagent/daemon/dist
COPY --from=builder /build/apps/runner-cli/dist/bundle.mjs /opt/sandagent/node_modules/@sandagent/runner-cli/dist/bundle.mjs
COPY --from=builder /build/apps/daemon/dist/bundle.mjs /opt/sandagent/node_modules/@sandagent/daemon/dist/bundle.mjs

# Init script (copy deps to workspace when needed)
RUN echo '#!/bin/bash\n\
if [ ! -d "/workspace/node_modules/@sandagent" ]; then\n\
  echo "Copying sandagent dependencies to workspace..."\n\
  mkdir -p /workspace/node_modules\n\
  cp -r /opt/sandagent/node_modules/* /workspace/node_modules/\n\
fi\n\
exec "$@"' > /usr/local/bin/sandagent-init && chmod +x /usr/local/bin/sandagent-init

# sandagent + sandagent-daemon commands
RUN echo '#!/usr/bin/env node' > /usr/local/bin/sandagent && \
    echo 'import("/opt/sandagent/node_modules/@sandagent/runner-cli/dist/bundle.mjs")' >> /usr/local/bin/sandagent && \
    chmod +x /usr/local/bin/sandagent
RUN echo '#!/usr/bin/env node' > /usr/local/bin/sandagent-daemon && \
    echo 'import("/opt/sandagent/node_modules/@sandagent/daemon/dist/bundle.mjs")' >> /usr/local/bin/sandagent-daemon && \
    chmod +x /usr/local/bin/sandagent-daemon

# Install global CLI tools for agent use
RUN npm install -g brave-search-cli

# Entrypoint: copy /skills, start daemon + optional CDP, then exec CMD
RUN printf '%s\n' \
    '#!/bin/bash' \
    'mkdir -p "$HOME/.claude/skills"' \
    'if [ -d /skills ] && [ -n "$(ls -A /skills 2>/dev/null)" ]; then' \
    '  cp -r /skills/. "$HOME/.claude/skills/"' \
    '  echo "Copied /skills to $HOME/.claude/skills"' \
    'fi' \
    'sandagent-daemon &' \
    'case "${START_CDP_ON_INIT:-1}" in' \
    '  0) echo "CDP startup disabled by START_CDP_ON_INIT=0" ;;' \
    '  *) start-cdp ;;' \
    'esac' \
    'exec "$@"' > /usr/local/bin/sandagent-entrypoint && \
    chmod +x /usr/local/bin/sandagent-entrypoint

ENV NODE_PATH=/opt/sandagent/node_modules
ENV PATH=/usr/local/bin:$PATH
ENV SANDAGENT_ROOT=/agent
ENV SANDAGENT_DAEMON_HOST=0.0.0.0
ENV SANDAGENT_DAEMON_PORT=3080
ENV START_CDP_ON_INIT=1

# Suppress D-Bus errors in headless Chromium (no bus in containers)
ENV DBUS_SESSION_BUS_ADDRESS=/dev/null

# Create CDP (Chrome DevTools Protocol) startup script
# Use nginx to proxy and rewrite Host header to localhost,
# bypassing Chromium's Host header security check
RUN for i in 1 2 3; do \
    apt-get update && apt-get install -y nginx && \
    rm -rf /var/lib/apt/lists/* && break || sleep 5; \
    done

RUN echo 'server {\n\
    listen 9222;\n\
    location / {\n\
        proxy_pass http://127.0.0.1:9223;\n\
        proxy_set_header Host localhost;\n\
        proxy_http_version 1.1;\n\
        proxy_set_header Upgrade $http_upgrade;\n\
        proxy_set_header Connection "upgrade";\n\
    }\n\
}' > /etc/nginx/conf.d/cdp-proxy.conf && \
    rm -f /etc/nginx/sites-enabled/default

RUN echo '#!/bin/bash\n\
set -e\n\
CHROME_BIN=$(node -e "console.log(require('"'"'playwright'"'"').chromium.executablePath())")\n\
"$CHROME_BIN" --headless --no-sandbox --disable-gpu --disable-dev-shm-usage --disable-software-rasterizer \\\n\
  --remote-debugging-port=9223 --remote-allow-origins=* 2>/dev/null &\n\
for i in $(seq 1 30); do\n\
  if curl -s http://127.0.0.1:9223/json/version > /dev/null 2>&1; then break; fi\n\
  sleep 0.5\n\
done\n\
nginx\n\
echo "CDP available on 0.0.0.0:9222 (nginx proxy rewriting Host to localhost)"' > /usr/local/bin/start-cdp && \
    chmod +x /usr/local/bin/start-cdp

EXPOSE 3080
EXPOSE 9222

ENTRYPOINT ["/usr/local/bin/sandagent-entrypoint"]
CMD ["sleep", "infinity"]
