{
  "name": "@bunny-agent/runner-pi",
  "version": "0.6.4-beta.0",
  "private": true,
  "description": "Pi agent runtime for BunnyAgent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "bunny-agent",
    "pi",
    "agent",
    "runner"
  ],
  "author": "BunnyAgent",
  "license": "Apache-2.0"
}
