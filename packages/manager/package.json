{
  "name": "@bunny-agent/manager",
  "version": "0.9.35",
  "description": "BunnyAgent Manager - Manages sandbox and runner lifecycle, defines core interfaces",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/bunny-agent.git",
    "directory": "packages/manager"
  },
  "keywords": [
    "sandbox",
    "agent",
    "bunny-agent",
    "runner",
    "manager"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
