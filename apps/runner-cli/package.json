{
  "name": "@bunny-agent/runner-cli",
  "version": "0.9.35",
  "description": "BunnyAgent Runner CLI - Like gemini-cli or claude-code, runs in your local terminal with AI SDK UI streaming",
  "type": "module",
  "bin": {
    "bunny-agent-runner": "./dist/bundle.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "Dockerfile"
  ],
  "scripts": {
    "build": "tsc && pnpm bundle",
    "build:bundle": "tsc && pnpm bundle",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --format=esm --external:dotenv --external:@anthropic-ai/claude-agent-sdk --external:@openai/codex-sdk --external:@earendil-works/pi-agent-core --external:@earendil-works/pi-ai --external:@earendil-works/pi-coding-agent --outfile=dist/bundle.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "test": "vitest run --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vikadata/bunny-agent.git",
    "directory": "apps/runner-cli"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "agent",
    "bunny-agent",
    "runner",
    "claude",
    "anthropic"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.70",
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@openai/codex-sdk": "^0.110.0",
    "dotenv": "^17.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bunny-agent/runner-harness": "workspace:*",
    "@bunny-agent/runner-claude": "workspace:*",
    "@bunny-agent/runner-codex": "workspace:*",
    "@bunny-agent/runner-gemini": "workspace:*",
    "@bunny-agent/runner-opencode": "workspace:*",
    "@bunny-agent/runner-pi": "workspace:*",
    "@types/node": "^20.10.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
